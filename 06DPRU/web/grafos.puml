@startuml
title Grafo fiel - verificarVelocidad (condición doble descompuesta + else-if real)

start
:2. Iniciando verificación...;

' Parte 1 del AND (3)
if (3. velocidad > limite?) then (Sí)

  ' Parte 2 del AND (4)
  if (4. esZonaEscolar?) then (Sí)
    :5. Multa grave: Exceso de velocidad\nen zona escolar.;
  else (No)
    ' entra al else-if y REEVALÚA velocidad > limite
    if (6. velocidad > limite?\n(reevaluación else-if)) then (Sí)
      :7. Multa leve: Exceso de velocidad.;
    else (No)
      :8. Velocidad dentro del límite.;
    endif
  endif

else (No)
  if (6. velocidad > limite?\n(reevaluación else-if)) then (Sí)
    :7. Multa leve: Exceso de velocidad.;
  else (No)
    :8. Velocidad dentro del límite.;
  endif
endif

:9. Verificación completada.;
stop
@enduml

